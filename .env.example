# Docker Compose environment variables (for web dashboard only)
# Copy to .env and adjust as needed

# Orch API runs on the HOST — web dashboard proxies to it
# Default: http://host.docker.internal:3001 (Docker → host)
# VITE_API_URL=http://host.docker.internal:3001

# Log level for native orch: debug, info, warn, error
ORCH_LOG_LEVEL=info
